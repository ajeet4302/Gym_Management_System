<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
 http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
 version="4.0">

<welcome-file-list>
<welcome-file>index.jsp</welcome-file>
</welcome-file-list>

<!-- Add Member -->

<servlet>
<servlet-name>AddMember</servlet-name>
<servlet-class>servlet.AddMemberServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>AddMember</servlet-name>
<url-pattern>/addMember</url-pattern>
</servlet-mapping>


<!-- View Members -->

<servlet>
<servlet-name>ViewMember</servlet-name>
<servlet-class>servlet.ViewMemberServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ViewMember</servlet-name>
<url-pattern>/viewMembers</url-pattern>
</servlet-mapping>


<!-- Delete Member -->

<servlet>
<servlet-name>DeleteMember</servlet-name>
<servlet-class>servlet.DeleteMemberServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>DeleteMember</servlet-name>
<url-pattern>/deleteMember</url-pattern>
</servlet-mapping>



<!-- Update Member -->

<servlet>
<servlet-name>UpdateMember</servlet-name>
<servlet-class>servlet.UpdateMemberServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>UpdateMember</servlet-name>
<url-pattern>/updateMember</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>AddTrainer</servlet-name>
<servlet-class>servlet.AddTrainerServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>AddTrainer</servlet-name>
<url-pattern>/addTrainer</url-pattern>
</servlet-mapping>


<servlet>
<servlet-name>ViewTrainer</servlet-name>
<servlet-class>servlet.ViewTrainerServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ViewTrainer</servlet-name>
<url-pattern>/viewTrainers</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>EditTrainer</servlet-name>
    <servlet-class>servlet.EditTrainerServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>EditTrainer</servlet-name>
    <url-pattern>/editTrainer</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeleteTrainer</servlet-name>
    <servlet-class>servlet.DeleteTrainerServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteTrainer</servlet-name>
    <url-pattern>/deleteTrainer</url-pattern>
</servlet-mapping> 
<servlet>
<servlet-name>LoginAdmin</servlet-name>
<servlet-class>servlet.LoginAdminServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>LoginAdmin</servlet-name>
<url-pattern>/loginAdmin</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>Logout</servlet-name>
    <servlet-class>servlet.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>Logout</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>

</web-app>